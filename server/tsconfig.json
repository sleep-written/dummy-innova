{
    "compilerOptions": {
        "strict": true,
        "target": "es2024",
        "module": "node20",
        "moduleResolution": "node16",
        "verbatimModuleSyntax": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,

        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": "src",
        "sourceMap": true,

        "paths": {
            "@entities/*": [ "./entities/*" ],
            "@server/*": [ "./server/*" ],
            "@utils/*": [ "./utils/*" ],
            "@/*": [ "./*" ]
        }
    }
}