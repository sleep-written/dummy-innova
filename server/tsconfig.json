{
    "compilerOptions": {
        "strict": true,
        "target": "es2024",
        "module": "node20",
        "moduleResolution": "node16",
        "verbatimModuleSyntax": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,

        "outDir": "dist",
        "rootDir": "src",
        "sourceMap": true,
        "lib": [ "ES2025" ],

        "paths": {
            "@orm-innova/*": [ "./src/orm-innova/*" ],
            "@orm-app/*": [ "./src/orm-app/*" ],
            "@server/*": [ "./src/server/*" ],
            "@utils/*": [ "./src/utils/*/index.ts", "./src/utils/*" ],
            "*": [ "./src/*" ]
        }
    }
}